<?xml version="1.0" encoding="UTF-8"?>
<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://maven.apache.org/POM/4.0.0" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.5.8</version>
        <relativePath/>
    </parent>

    <groupId>edu.kit.iai.webis</groupId>
    <artifactId>proof-config-manager</artifactId>
    <version>1.4.17-local</version>
    <name>PROOF Config Manager</name>
    <description>PROOF Config Manager</description>
    <packaging>jar</packaging>

    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <gitHost>gitlab.kit.edu/</gitHost>
        <gitUserId>kit/iai/webis/proof2</gitUserId>
        <gitRepoId>proof-config-manager</gitRepoId>
        <lombok.version>1.18.38</lombok.version>
        <model.version>3.4.1</model.version>
    </properties>

    <dependencies>

        <!-- PROOF Dependencies-->
        <dependency>
            <groupId>edu.kit.iai.webis</groupId>
            <artifactId>proof-models</artifactId>
            <version>${model.version}</version>
        </dependency>

        <!-- Spring Security -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-oauth2-resource-server</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-oauth2-client</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-messaging</artifactId>
        </dependency>

        <!-- Misc Dependencies-->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-cache</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-redis</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-websocket</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-configuration-processor</artifactId>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <version>${lombok.version}</version>
        </dependency>
        <dependency>
            <groupId>org.springdoc</groupId>
            <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
            <version>2.3.0</version>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-webflux</artifactId>
        </dependency>
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>com.h2database</groupId>
            <artifactId>h2</artifactId>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>io.netty</groupId>
            <artifactId>netty-resolver-dns-native-macos</artifactId>
            <classifier>osx-aarch_64</classifier>
            <version>4.1.112.Final</version>
        </dependency>
        <dependency>
            <groupId>org.springframework.amqp</groupId>
            <artifactId>spring-rabbit</artifactId>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.datatype</groupId>
            <artifactId>jackson-datatype-jsr310</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.14.1</version>
                <configuration>
                    <excludes>
                        <exclude>generated/**</exclude>
                    </excludes>
                    <annotationProcessorPaths>
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                            <version>1.18.30</version>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.5.4</version>
                <configuration>
                    <argLine>-ea -XX:+EnableDynamicAgentLoading -Xshare:off</argLine>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <version>3.5.8</version>
                <configuration>
                    <jmxPort>9009</jmxPort>
                    <jvmArguments>-ea -XX:+EnableDynamicAgentLoading -Xshare:off</jvmArguments>
                    <mainClass>com.smateso.proof.App</mainClass>
                    <excludes>
                        <exclude>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </exclude>
                    </excludes>
                </configuration>
                <executions>
                    <execution>
                        <configuration>
                            <profiles>test</profiles>
                            <jvmArguments>-ea -XX:+EnableDynamicAgentLoading -Xshare:off</jvmArguments>
                        </configuration>
                        <goals>
                            <goal>start</goal>
                            <goal>stop</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.springdoc</groupId>
                <artifactId>springdoc-openapi-maven-plugin</artifactId>
                <version>1.4</version>
                <executions>
                    <execution>
                        <id>integration-test</id>
                        <phase>integration-test</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <apiDocsUrl>http://localhost:8100/v3/api-docs</apiDocsUrl>
                            <outputFileName>api.json</outputFileName>
                            <outputDir>${project.build.directory}</outputDir>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.openapitools</groupId>
                <artifactId>openapi-generator-maven-plugin</artifactId>
                <version>7.17.0</version>
                <executions>
                    <execution>
                        <id>gen-typescript</id>
                        <phase>post-integration-test</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <verbose>false</verbose>
                            <cleanupOutput>true</cleanupOutput>
                            <enablePostProcessFile>true</enablePostProcessFile>
                            <inputSpec>${project.build.directory}/api.json</inputSpec>
                            <output>${project.basedir}/generated/typescript</output>
                            <generatorName>typescript-axios</generatorName>
                            <gitHost>${gitHost}</gitHost>
                            <gitUserId>${gitUserId}</gitUserId>
                            <gitRepoId>${gitRepoId}</gitRepoId>
                            <additionalProperties>
                                <additionalProperty>apiPackage=api</additionalProperty>
                                <additionalProperty>modelPackage=model</additionalProperty>
                                <additionalProperty>withSeparateModelsAndApi=true</additionalProperty>
                                <additionalProperty>supportsES6=true</additionalProperty>
                                <additionalProperty>withInterfaces=true</additionalProperty>
                                <additionalProperty>npmVersion=${project.version}</additionalProperty>
                                <additionalProperty>npmName=@webis/proof-config-manager-client</additionalProperty>
                            </additionalProperties>
                        </configuration>
                    </execution>
                    <execution>
                        <id>gen-java</id>
                        <phase>post-integration-test</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <configOptions>
                                <java8>true</java8>
                                <dateLibrary>custom</dateLibrary>
                                <openApiNullable>false</openApiNullable>
                                <interfaceOnly>true</interfaceOnly>
                            </configOptions>
                            <typeMappings>
                                <typeMapping>DateTime=Instant</typeMapping>
                                <typeMapping>Date=Date</typeMapping>
                            </typeMappings>
                            <importMappings>
                                <importMapping>Instant=java.time.Instant</importMapping>
                                <importMapping>Date=java.util.Date</importMapping>
                            </importMappings>
                            <verbose>false</verbose>
                            <cleanupOutput>true</cleanupOutput>
                            <enablePostProcessFile>true</enablePostProcessFile>
                            <inputSpec>${project.build.directory}/api.json</inputSpec>
                            <output>${project.basedir}/generated/java</output>
                            <library>webclient</library>
                            <generatorName>java</generatorName>
                            <gitHost>${gitHost}</gitHost>
                            <gitUserId>${gitUserId}</gitUserId>
                            <gitRepoId>${gitRepoId}</gitRepoId>
                            <gitHost>gitlab.kit.edu</gitHost>
                            <artifactId>config-manager-client</artifactId>
                            <groupId>edu.kit.iai.webis.proof</groupId>
                            <artifactVersion>${project.version}</artifactVersion>
                            <apiPackage>edu.kit.iai.webis.proofapi</apiPackage>
                            <modelPackage>edu.kit.iai.webis.proofmodels</modelPackage>
                            <additionalProperties>
                                <additionalProperty>annotationLibrary=swagger2</additionalProperty>
                                <additionalProperty>serializationLibrary=jackson</additionalProperty>
                            </additionalProperties>
                        </configuration>
                    </execution>
                    <execution>
                        <id>gen-python</id>
                        <phase>post-integration-test</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <generateApis>false</generateApis>
                            <generateModels>true</generateModels>
                            <verbose>false</verbose>
                            <cleanupOutput>true</cleanupOutput>
                            <enablePostProcessFile>true</enablePostProcessFile>
                            <inputSpec>${project.build.directory}/api.json</inputSpec>
                            <output>${project.basedir}/generated/python</output>
                            <generatorName>python</generatorName>
                            <gitHost>${gitHost}</gitHost>
                            <gitUserId>${gitUserId}</gitUserId>
                            <gitRepoId>${gitRepoId}</gitRepoId>
                            <gitHost>gitlab.kit.edu</gitHost>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>com.google.cloud.tools</groupId>
                <artifactId>jib-maven-plugin</artifactId>
                <version>3.4.6</version>
                <configuration>
                    <container>
                        <creationTime>USE_CURRENT_TIMESTAMP</creationTime>
                    </container>
                    <from>
                        <image>azul/zulu-openjdk:21</image>
                    </from>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <repositories>
        <repository>
            <id>iai-artifactory</id>
            <url>https://iai-artifactory.iai.kit.edu/artifactory/webis/</url>
        </repository>
    </repositories>

    <distributionManagement>
        <repository>
            <id>iai-artifactory</id>
            <name>iai-artifactory</name>
            <url>https://iai-artifactory.iai.kit.edu/artifactory/webis-common</url>
        </repository>
    </distributionManagement>

</project>
